# API Configuration
VITE_API_BASE_URL=http://localhost:4800/api/v1

# Dev: `pnpm dev` sirve el frontend en HTTPS (vite + @vitejs/plugin-basic-ssl) para Mercado Pago Bricks.
# Abre la URL que muestre Vite, p. ej. https://localhost:3920 (acepta el certificado autofirmado en el navegador).

# App Configuration
VITE_APP_NAME=MishiWoof
VITE_APP_VERSION=1.0.0

# Features
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_SENTRY=false

# Opcional: Para desarrollo
VITE_MOCK_API=false

# Mercado Pago (Checkout API / Bricks — clave pública del vendedor)
# VITE_MP_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
